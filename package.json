{
  "name": "finanzas-facil",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:web": "tsc -b && vite build && node scripts/postbuild-sitemap.js && node scripts/postbuild-cookie-consent.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:all": "bash scripts/build-all.sh",
    "update:ios": "bash scripts/update-ios.sh",
    "update:android": "bash scripts/update-android.sh",
    "update:web": "bash scripts/update-web.sh",
    "purge-cdn": "node scripts/purge-cdn.js",
    "deploy:fresh": "npm run build:web && bash scripts/update-web.sh && npm run purge-cdn",
    "sync:ios": "npm run build && npx cap sync ios",
    "sync:android": "npm run build && npx cap sync android",
    "sync:all": "npm run build && npx cap sync"
  },
  "dependencies": {
    "@capacitor-community/admob": "^7.0.3",
    "@capacitor-firebase/app": "^7.3.1",
    "@capacitor-firebase/authentication": "^7.3.1",
    "@capacitor/android": "^7.4.3",
    "@capacitor/cli": "^7.4.3",
    "@capacitor/core": "^7.4.3",
    "@capacitor/filesystem": "^7.1.4",
    "@capacitor/ios": "^7.4.3",
    "@capacitor/preferences": "^7.0.2",
    "@capacitor/push-notifications": "^7.0.3",
    "@capacitor/share": "^7.0.2",
    "@types/jspdf": "^1.3.3",
    "capacitor-plugin-app-tracking-transparency": "^2.0.5",
    "chart.js": "^4.5.0",
    "firebase": "^12.3.0",
    "jspdf": "^3.0.4",
    "lucide-react": "^0.263.1",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.5",
    "react-is": "^19.2.3",
    "recharts": "^3.6.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.0.3",
    "autoprefixer": "^10.4.14",
    "eslint": "^8.45.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "postcss": "^8.4.27",
    "puppeteer": "^24.26.1",
    "sharp": "^0.34.4",
    "tailwindcss": "^3.3.3",
    "typescript": "^5.0.2",
    "vite": "^4.4.5"
